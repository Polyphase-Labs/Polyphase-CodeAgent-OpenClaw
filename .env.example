# Copy to .env and fill in. Docker Compose auto-loads .env.

# Required: PAT for the target repo. Needs:
#   Contents: read+write
#   Pull requests: read+write
# Generate at https://github.com/settings/personal-access-tokens (fine-grained)
# or use a classic PAT with the `repo` scope.
GITHUB_TOKEN=

# Optional: repo the agent works on. Defaults to the public engine.
# POLYPHASE_REPO=https://github.com/Polyphase-Labs/Polyphase-Engine

# Optional: base branch PRs are opened against.
# GITHUB_BASE_BRANCH=main

# Optional: commit author identity.
# GIT_AUTHOR_NAME=Polyphase Code Agent
# GIT_AUTHOR_EMAIL=codeagent@polyphase.local

# Optional: override the Control UI auth token (default is "polyphase").
# GATEWAY_TOKEN=my-secret-token

# Optional: comma-separated CORS origins if you access the Control UI from
# a host other than localhost.
# ALLOWED_ORIGINS=http://localhost:3348,https://myhost.example.com
